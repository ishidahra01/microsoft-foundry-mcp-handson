# ─────────────────────────────────────────────────────────────────────────────
# Foundry OAuth UI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# (Required) Azure AI Foundry project endpoint
# Format: https://<your-project>.services.ai.azure.com/api/projects/<project-id>
# Or the older format: https://<hub>.openai.azure.com/
PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project-id

# (Required) Foundry Agent selector
# Specify one of the following:
#  1) AGENT_REFERENCE_NAME: sent as `agent_reference` (recommended)
#  2) AGENT_ID: sent as `model` (backward compatibility)
# If both are set, AGENT_REFERENCE_NAME is prioritized.
AGENT_REFERENCE_NAME=your-agent-name

# (Optional) Comma-separated list of CORS origins allowed to call this server.
# Default: http://localhost:3000 (Next.js dev server)
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────────────────────
# The server uses DefaultAzureCredential (azure-identity) to acquire a token
# for the "https://ai.azure.com/.default" scope.
#
# In local development, run:  az login
# In production (Azure App Service / Container Apps):
#   - Assign a User-Assigned or System-Assigned Managed Identity with the
#     "Azure AI User" role on the Foundry project.
#   - Set AZURE_CLIENT_ID if using a User-Assigned identity.
#
# AZURE_CLIENT_ID=<managed-identity-client-id>   # optional for UAMI
